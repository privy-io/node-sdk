{
  "name": "@privy-io/node",
  "version": "0.19.0",
  "description": "The official TypeScript library for the Privy API",
  "author": "Privy API <support@privy.io>",
  "types": "dist/index.d.ts",
  "main": "dist/index.js",
  "type": "commonjs",
  "repository": "github:privy-io/node-sdk",
  "license": "Apache-2.0",
  "packageManager": "yarn@1.22.22",
  "files": [
    "**/*"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "test": "./scripts/test",
    "test:integration": "jest --testPathPattern=tests/integration --verbose --testTimeout 30000",
    "build": "./scripts/build",
    "prepublishOnly": "echo 'to publish, run yarn build && (cd dist; yarn publish)' && exit 1",
    "format": "./scripts/format",
    "prepare": "if ./scripts/utils/check-is-in-git-install.sh; then ./scripts/build && ./scripts/utils/git-swap.sh; fi",
    "tsn": "ts-node -r tsconfig-paths/register",
    "lint": "./scripts/lint",
    "fix": "./scripts/format"
  },
  "dependencies": {
    "@hpke/chacha20poly1305": "^1.7.1",
    "@hpke/core": "^1.7.5",
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "@scure/base": "^1.2.5",
    "canonicalize": "^2.1.0",
    "jose": "^6.1.0",
    "lru-cache": "^11.1.0",
    "svix": ">=1.29.0 <= 1.37.0 || ^1.40.0"
  },
  "peerDependencies": {
    "@solana/kit": "^5.1.0",
    "@x402/evm": "^2.3.0",
    "@x402/fetch": "^2.3.0",
    "@x402/svm": "^2.3.0",
    "viem": "^2.24.1"
  },
  "peerDependenciesMeta": {
    "@solana/kit": {
      "optional": true
    },
    "@x402/evm": {
      "optional": true
    },
    "@x402/fetch": {
      "optional": true
    },
    "@x402/svm": {
      "optional": true
    },
    "viem": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.17.0",
    "@solana-program/system": "^0.10.0",
    "@solana/kit": "^5.1.0",
    "@solana/web3.js": "^1.98.4",
    "@swc/core": "^1.3.102",
    "@swc/jest": "^0.2.29",
    "@types/jest": "^29.4.0",
    "@types/node": "^20.17.6",
    "@typescript-eslint/eslint-plugin": "8.31.1",
    "@typescript-eslint/parser": "8.31.1",
    "@x402/evm": "^2.3.0",
    "@x402/fetch": "^2.3.0",
    "@x402/svm": "^2.3.0",
    "bip39": "^3.1.0",
    "dotenv": "^17.2.1",
    "ed25519-hd-key": "^1.3.0",
    "eslint": "^9.39.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "iconv-lite": "^0.6.3",
    "jest": "^29.4.0",
    "prettier": "^3.0.0",
    "publint": "^0.2.12",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.5.0",
    "tsc-multi": "https://github.com/stainless-api/tsc-multi/releases/download/v1.1.11/tsc-multi.tgz",
    "tsconfig-paths": "^4.0.0",
    "tslib": "^2.8.1",
    "tweetnacl": "^1.0.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.31.1",
    "viem": "^2.34.0"
  },
  "overrides": {
    "minimatch": "^9.0.5"
  },
  "pnpm": {
    "overrides": {
      "minimatch": "^9.0.5"
    }
  },
  "resolutions": {
    "minimatch": "^9.0.5"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./viem": {
      "import": {
        "types": "./dist/viem.d.mts",
        "default": "./dist/viem.mjs"
      },
      "require": {
        "types": "./dist/viem.d.ts",
        "default": "./dist/viem.js"
      }
    },
    "./solana-kit": {
      "import": {
        "types": "./dist/solana-kit.d.mts",
        "default": "./dist/solana-kit.mjs"
      },
      "require": {
        "types": "./dist/solana-kit.d.ts",
        "default": "./dist/solana-kit.js"
      }
    },
    "./x402": {
      "import": {
        "types": "./dist/x402.d.mts",
        "default": "./dist/x402.mjs"
      },
      "require": {
        "types": "./dist/x402.d.ts",
        "default": "./dist/x402.js"
      }
    }
  }
}
