{
  "dxt_version": "0.2",
  "name": "@privy-io/node-mcp",
  "version": "0.10.1",
  "description": "The official MCP Server for the Privy API API",
  "author": {
    "name": "Privy API",
    "email": "support@privy.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/privy-io/node-sdk.git"
  },
  "homepage": "https://github.com/privy-io/node-sdk/tree/main/packages/mcp-server#readme",
  "documentation": "https://docs.privy.io",
  "server": {
    "type": "node",
    "entry_point": "index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/index.js"],
      "env": {
        "PRIVY_APP_ID": "${user_config.PRIVY_APP_ID}",
        "PRIVY_APP_SECRET": "${user_config.PRIVY_APP_SECRET}"
      }
    }
  },
  "user_config": {
    "PRIVY_APP_ID": {
      "title": "appId",
      "description": "App secret authentication.",
      "required": true,
      "type": "string"
    },
    "PRIVY_APP_SECRET": {
      "title": "appSecret",
      "description": "App secret authentication.",
      "required": true,
      "type": "string"
    }
  },
  "tools": [],
  "tools_generated": true,
  "compatibility": {
    "runtimes": {
      "node": ">=18.0.0"
    }
  },
  "keywords": ["api"]
}
